# =====================================================================
# backend-klinik-sofeng — environment template
# Salin file ini menjadi `.env` lalu isi nilai aslinya.
# JANGAN commit `.env` (sudah di .gitignore).
# =====================================================================

# ------- App -------
NODE_ENV=development
PORT=4000

# CORS allowed origins (pisahkan dengan koma jika lebih dari satu).
# Frontend Next.js dev defaultnya http://localhost:3000.
ALLOWED_ORIGINS=http://localhost:3000

# ------- Supabase -------
# Dapatkan dari Supabase Dashboard → Project Settings → API.

# Project URL, contoh: https://abcdefghijklmnop.supabase.co
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# anon (public) key — boleh dipakai dari client, di sini untuk verifikasi token.
SUPABASE_ANON_KEY=your-anon-key

# service_role key — HANYA server-side. JANGAN pernah expose ke frontend.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
