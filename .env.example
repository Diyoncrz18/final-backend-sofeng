# =====================================================================
# backend-klinik-sofeng — environment template
# Salin file ini menjadi `.env` lalu isi nilai aslinya.
# JANGAN commit `.env` (sudah di .gitignore).
# =====================================================================

# ------- App -------
NODE_ENV=development
PORT=4000

# CORS allowed origins (pisahkan dengan koma jika lebih dari satu).
# Frontend Next.js dev defaultnya http://localhost:3000.
ALLOWED_ORIGINS=http://localhost:3000

# ------- Supabase -------
# Dapatkan dari Supabase Dashboard → Project Settings → API.

# Project URL, contoh: https://abcdefghijklmnop.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# anon (public) key — boleh dipakai dari client, di sini untuk verifikasi token.
SUPABASE_ANON_KEY=your-anon-public-key

# service_role key — HANYA server-side. JANGAN pernah expose ke frontend.
# Bypass RLS, jadi treat seperti password root. Wajib di-rotate kalau pernah bocor.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ------- Auth / Cookies -------
# Refresh token cookie (httpOnly) — wajib diatur di production.
# Generate via: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Tidak dipakai untuk sign cookie (kita pakai Supabase JWT) tapi reserved untuk
# CSRF token / future use.
COOKIE_DOMAIN=
# Setel "true" di production (HTTPS).
COOKIE_SECURE=false
