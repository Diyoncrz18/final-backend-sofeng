{
  "name": "backend-klinik-sofeng",
  "version": "0.1.0",
  "private": true,
  "description": "REST API backend untuk Klinik Gigi (tugas Software Engineering). Frontend: ../klinik-sofeng (Next.js).",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
